{
  "name": "movie-op-frontend",
  "version": "1.0.0",
  "description": "Movie Op Frontend",
  "scripts": {
    "build:css": "cleancss -o css/styles.min.css css/styles.css",
    "build:js": "terser js/app.js -o js/app.min.js -c -m",
    "build": "npm run build:css && npm run build:js",
    "serve": "python -m http.server 8000"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.2",
    "terser": "^5.19.2"
  }
}
